# 方式一：有域名（Caddy 自动申请 HTTPS 证书）
# your-domain.com {
#     reverse_proxy /api/* localhost:5001
#     reverse_proxy /admin/* localhost:5001
#     reverse_proxy /uploads/* localhost:5001
#     reverse_proxy localhost:3000
# }

# 方式二：仅用 IP 访问（HTTP，无证书）
:80 {
    # API 和管理后台由 Express 处理
    reverse_proxy /api/* localhost:5001
    reverse_proxy /admin/* localhost:5001
    reverse_proxy /uploads/* localhost:5001

    # 其余请求由 Nuxt 处理
    reverse_proxy localhost:3000
}
